{
  "name": "video-dubbing-desktop",
  "version": "3.0.0",
  "private": true,
  "description": "Standalone local-first AI video dubbing desktop application",
  "main": "dist-electron/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron -c cyan,magenta \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "wait-on http://127.0.0.1:5174 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5174 node scripts/run-electron.cjs",
    "build:electron": "node -e \"require('fs').rmSync('dist-electron',{recursive:true,force:true})\" && tsc -p electron/tsconfig.json && node -e \"require('fs').writeFileSync('dist-electron/package.json', JSON.stringify({type:'commonjs'}, null, 2))\" && cross-env ELECTRON_RUN_AS_NODE=1 electron scripts/compile-bytenode.cjs",
    "build": "npm run build:electron && vite build",
    "start": "node scripts/run-electron.cjs",
    "typecheck": "tsc --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "package": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win zip",
    "package:dir": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --dir --win",
    "package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./window-package.ps1",
    "package:zip": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win zip --prepackaged release/win-unpacked"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "bytenode": "^1.6.0",
    "dy-downloader": "^0.2.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "studio.videodubbing.desktop",
    "productName": "Video Clone",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**/*",
          "!**/*.pyc",
          "!**/*.lib",
          "!**/*.a",
          "!**/.venv/**/*"
        ]
      },
      {
        "from": "omnivoice",
        "to": "omnivoice",
        "filter": [
          "**/*",
          "!**/__pycache__/**/*",
          "!**/*.pyc",
          "!**/*.lib",
          "!**/*.a"
        ]
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "signAndEditExecutable": false,
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": "AppImage",
      "category": "AudioVideo"
    }
  },
  "allowScripts": {
    "electron@35.7.5": true,
    "esbuild@0.25.12": true
  }
}
